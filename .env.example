# Vultr sandbox host: Compose rejects this empty example value. Generate with:
# openssl rand -hex 32
CRASHDIAG_SANDBOX_TOKEN=

# Optional service bounds (shown with their defaults).
CRASHDIAG_MAX_SESSIONS=128
CRASHDIAG_SESSION_TTL_SECONDS=900
CRASHDIAG_MAX_OPERATIONS_PER_SESSION=64
CRASHDIAG_MAX_WORKERS=64
CRASHDIAG_REQUEST_TIMEOUT_SECONDS=10

# Trusted dataset-generation machine or Kaggle only. Never copy HF_TOKEN onto
# the Vultr sandbox. Use a fine-grained write token for this private bucket.
HF_TOKEN=
CRASHDIAG_HF_BUCKET_ID=devaanshpa/CrashDiag
CRASHDIAG_ARTIFACT_PREFIX=runs
CRASHDIAG_ARTIFACT_LOCAL_ROOT=artifacts
CRASHDIAG_ARTIFACT_UPLOAD_POLICY=required
# Set true only for the first preflight if the named bucket does not exist.
CRASHDIAG_CREATE_ARTIFACT_BUCKET=false

# Dataset generation and scripts/train.sh generate unique values automatically.
# Set this explicitly only when resuming the same partial bucket prefix.
# CRASHDIAG_RUN_ID=20260719T120000Z-commit-random

# Kaggle reaches the Vultr service through Caddy on HTTPS/443.
CRASHDIAG_SANDBOX_URL=https://sandbox.devaanshpathak.com
